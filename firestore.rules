rules_version = '2';

// Álbuns compartilhados por família: /albums/{albumId}, onde albumId é o id da
// família (ex: 'vini-vivi') e os membros são listados em albumMembers().
// Cada membro lê e escreve no álbum da sua família; ninguém acessa o de outra.
service cloud.firestore {
  match /databases/{database}/documents {
    // Mantenha igual ao ALBUMS de js/auth.js. Cada álbum é compartilhado pela família.
    function albumMembers() {
      return {
        'vini-vivi': ['vinigm@gmail.com', 'victoria.cerutti@gmail.com']
        // , 'eduardo': ['eduardo@gmail.com', 'esposa@gmail.com', 'filha1@gmail.com', 'filha2@gmail.com']
      };
    }

    match /albums/{albumId} {
      // Membros do álbum (família) leem e escrevem nele.
      allow read, write: if request.auth != null
        && albumId in albumMembers()
        && request.auth.token.email.lower() in albumMembers()[albumId];
      // Transitório (migração): cada um pode LER seu antigo álbum pessoal (id = uid).
      allow read: if request.auth != null && albumId == request.auth.uid;
    }
  }
}
