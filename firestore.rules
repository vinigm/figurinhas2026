rules_version = '2';

// Cadastro guiado por dados em /config/app:
//   members:  { 'email': 'albumId' }   → quem pode usar e qual álbum cada um edita
//   families: { 'albumId': 'Nome' }    → nomes das famílias (rótulos)
// Regras:
//   - Qualquer pessoa CADASTRADA lê todos os álbuns (pra trocas).
//   - Cada um só ESCREVE no álbum da sua família.
//   - Só o admin (vinigm@gmail.com) edita o cadastro.
service cloud.firestore {
  match /databases/{database}/documents {
    function emailLower() {
      return request.auth != null ? request.auth.token.email.lower() : '';
    }
    function isAdmin() {
      return emailLower() == 'vinigm@gmail.com';
    }
    function cfg() {
      return get(/databases/$(database)/documents/config/app).data;
    }
    function isMember() {
      return request.auth != null && emailLower() in cfg().members;
    }
    function myAlbum() {
      return cfg().members[emailLower()];
    }

    // Cadastro: cadastrados (e o admin) leem; só o admin escreve.
    match /config/app {
      allow read: if isAdmin() || isMember();
      allow write: if isAdmin();
    }

    // Álbuns: todo cadastrado lê qualquer um; cada um escreve só no da sua família.
    match /albums/{albumId} {
      allow read: if isMember();
      allow write: if (isMember() && myAlbum() == albumId) || isAdmin();
      // Transitório (migração antiga): ler o próprio álbum pessoal por uid.
      allow read: if request.auth != null && albumId == request.auth.uid;
    }
  }
}
